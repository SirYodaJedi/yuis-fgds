//
// Quake 3 Arena entity definition file (.fgd)
// for J.A.C.K. 1.1.3773 and above
//
// Version 1.7.3.J1
// 
// Based on entites.ent for GtkRadiant 1.5 (v1.7.3, updated 2011-03-02)
// Based on draft by Suicide 20 7.30.99 and inolen 9-3-99
// Upgraded by Eutectic: eutectic@ritualistic.com
// (visible models added by raYGunn - paths provided by Suicide 20)
// (terrain information added to func_group entity by Paul Jaquays)
// Q3Map2 entities/keys added by ydnar
// Additional Q3Map2 and Q3A PR 1.32 entities/keys added by Obsidian
//
// Converted to FGD by DEF2FGD 1.2 by FreeSlave
// Refactored and expanded by SirYodaJedi
//

@mapsize(-65536, 65536)

//
// Worldspawn
//

@SolidClass = worldspawn : "World entity, which stores regular static map primitives (brushes and patches)."
[
	// can't use "shader" KV type in Worldspawn due to JACK bug with texture browser
	
	_comment(string) : "Editor Comment" : : "Field that is ignored by the game and compilers. Can be used for quick locational notes when mapping."
	message(string) : "Logon Message" : "TODO - set map name" : "Text to print at user logon. Used for name of level."
	author(string) : "Primary Map Author" : : "Quake Live only, but might as well fill it out."
	author2(string) : "Secondary Map Author" : : "Quake Live only, but might as well fill it out."
	music(sound) : "Music File" : : "Path/name of looping .wav file used for level's music (e.g. music/sonic5.wav). Specifying two files, like 'music/fla22k_04_intro.wav music/fla22k_04_loop.wav' will make former to play once and latter looped then.\nMust be stereo. The game will print warning if the sample rates aren't 22050 Hz, but 44100 and 11025 are perfectly valid (but 44 kHz results in a lot of file bloat, and 11 kHz sounds horribly muffled, so sticking to 22 kHz is recommended).\n\nWAV file extension is automatically applied (OGG if Quake Live) if no file extension is specified."
	gravity(float) : "Gravity" : 800 : "Gravity of level (default normal gravity: 800)."
	disable_loadout(string) : "Prohibited weapons (Quake Live)" : : "Quake Live only: Space-delineated list "
	
	// "g",		// WP_GAUNTLET
	// "mg",	// WP_MACHINEGUN
	// "sg",	// WP_SHOTGUN
	// "gl",	// WP_GRENADE_LAUNCHER
	// "rl",	// WP_ROCKET_LAUNCHER
	// "lg",	// WP_LIGHTNING
	// "rg",	// WP_RAILGUN
	// "pg",	// WP_PLASMAGUN
	// "bfg",	// WP_BFG
	// "gh",	// WP_GRAPPLING_HOOK
	// "ng",	// WP_NAILGUN
	// "pl",	// WP_PROX_LAUNCHER
	// "cg",	// WP_CHAINGUN
	// "hmg",	// WP_HMG
	
	// Team Arena atmospheric effects
	enableDust(choices) : "Enable Dust" : 1 : "Team Arena and Quake Live only. Draw dust particles when walking on materials with ''surfaceParm dust''. " =
	[
		"" : "No"
		1 : "Yes"
	]
	enableBreath(choices) : "Enable Cold Breath Particles" : : "Team Arena only. Draw breath particles on players." =
	[
		"" : "No"
		1 : "Yes"
	]
	
	// Q3MAP2 keys
	gridsize(string) : "Dynamic Light Granularity" : "64 64 128" : "Granularity of the lightgrid, created by q3map, which is used to dynamically light certain game objects, like players and items. Value is three integers separated by spaces, representing number of units between grid points in X Y Z. Default gridsize value is 64 64 128. Use larger powers of 2 to reduce BSP size and compile time on very large maps."
	_blocksize(string) : "BSP Block Size" : "1024 1024 1024" : "Map compiler splits the BSP tree along axial planes (X, Y and Z) for optimization. It does it as often, as specified in _blocksize key for respective axis (in units) (default 1024 1024 1024, 0 = disable, setting single value 'N' equals to setting 'N N N'). I.e. lower values result in more splits and vice versa. Increase the blocksize using larger powers of 2 to reduce compile times on very large maps with a low structural brush density. Maps, having flat architecture, might work better with horizontal splits disabled ('N N 0')."
	_ambient(float) : "Ambient Intensity" :  : "Adds a constant value to overall lighting (default 0, range 0 - 255). Use is not recommended. It has a tendency to flatten out variations in light and shade."
	_color(color1) : "Ambient Color" :  : "RGB color value for ambient and other global light parameters (default is 1 1 1)."
	_minlight(float) : "Min Lightmap Intensity " : : "Minimum light value, levelwide. Uses the _color key to set color. Since it does not add unlike ambient, but overrides existing light values, affected areas will get flat constant light. Not recommended on worldspawn; should be used on specific entities (ex: func_door) that get faces which are going to be inevitably pitch black due to spawning obscured."
	_minvertexlight(float) : "Min Vertex Intensity" : : "Minimum vertex lighting, levelwide. Not recommended."
	_mingridlight(float) : "Min Dynamic Intensity" : : "Minimum lightgrid (dynamic entity lighting) levelwide."
	_floodlight(string) : "Floodlight" : : "A sextet of values r g b dist intensity directional_power to set global floodlight parameters (good defaults are 240 240 255 1024 128 1). Floodlight effect is sort of Ambient Occlusion."
	_keeplights(choices) : "Keep Light Entities" : : "Keep light* entities in the BSP. Normally stripped out by the BSP process and read from the .map file by the lighting phase." =
	[
		"" : "No"
		1 : "Yes"
	]
	_keepModels(choices) : "Keep misc_model Entities" : : "Keep misc_model entities in the BSP. Normally stripped out by the BSP process after baking into the map." =
	[
		"" : "No"
		1 : "Yes"
	]
	_noshadersun(choices) : "Ignore Shader Sun" : : "Ignore q3map_sun/sun directives in sky shaders and ONLY use entity sun lights." =
	[
		"" : "No"
		1 : "Yes"
	]
	_farplanedist(float) : "Far Clip Distance" : : "Limit on how many units the vis phase of compilation can see. Used in combination with level-wide fog, it can help reduce r_speeds on large, open maps."
	_foghull(string) : "Fog Hull Shader" : : "Shader to use for fog hull. Foghull shader should be a sky shader. Omit the textures/ prefix."
	_lightmapscale(float) : "Lightmap Scale" : "1.0" : "Floating point value, scaling the resolution of lightmaps on brushes/patches in the world. Can be overridden in func_group (or other entities) (default 1.0)."
	_castshadows(integer) : "Shadow Caster Level" : 1 : "Allows per-entity control over shadow casting. Defaults to 0 on entities, 1 on world. 0 = no shadow casting. 1 = cast shadows on world. > 1 = cast shadows on entities with _rs (or _receiveshadows) with the corresponding value, AND world. Negative values imply same, but DO NOT cast shadows on world."
	_receiveshadows(integer) : "Shadow Receiver Level" : 1 : "Allows per-entity control over shadow reception. Defaults to 1 on everything (world shadows). 0 = receives NO shadows. > 1 = receive shadows only from corresponding keyed entities (see above) and world. < 1 = receive shadows ONLY from corresponding keyed entities."
	_celshader(string) : "Cel Shader" : : "Sets the cel shader used for this geometry. Note: Omit the textures/ prefix."
	_style1alphaGen(string) : "Style Light alphaGen" : : "Values takes standard shader waveform functions (e.g. wave sin 0.5 0.3 0.25 1.5)\nAdditional keyvalues can be added as-needed, up to _style31alphaGen."
	_style1rgbGen(string) : "Style Light rgbGen" : : "Values take standard shader waveform functions (e.g. wave sin 0.5 0.3 0.25 1.5)\nAdditional keyvalues can be added as-needed, up to _style31rgbGen."
	
	// Q3Map2 meta keys
	_indexmap(string) : "Terrain Blending Map" : : "Path/name for the art file used to guide the mapping of textures on the terrain surface."
	_layers(integer) : "Terrain Layers" : : "Number of unique root shaders that will be used on the terrain."
	_shader(string) : "Terrain MetaShader" : : "Path to the metashader used to assign textures to the terrain entity. Note: Omit the textures/ prefix."
]

//
// Base classes
//

@BaseClass = Angles
[
	// `angle` is commented-out because Jack annoyingly prioritizes it even if empty
	//angle(float) : "Yaw Angle (deprecated)" : : "Like `angles`, but only affects the Z axis."
	angles(angle) : "Pitch Yaw Roll (Y Z X)" : "0 0 0" : "Individual control of PITCH, YAW, and ROLL (default 0 0 0)."
]

@BaseClass = EditorComment
[
	_comment(string) : "Editor Comment" : : "Field that is ignored by the game and compilers. Can be used for quick locational notes when mapping."
]

// All runtime entities have this, so include _comment. 
@BaseClass base(EditorComment) = GameModes
[
	notfree(choices) : "Not in FFA" : : "When set to 1, entity will not spawn in Free for All and Tournament modes." =
	[
		"" : "No"
		1 : "Yes"
	]
	notteam(choices) : "Not in Teamplay" : : "When set to 1, entity will not spawn in Teamplay and CTF modes." =
	[
		"" : "No"
		1 : "Yes"
	]
	notsingle(choices) : "Not in Singleplayer" : : "When set to 1, entity will not spawn in Single Player mode (bot play mode). Ignored in Quake Live." =
	[
		"" : "No"
		1 : "Yes"
	]
	notq3a(choices) : "Not in Base Quake III" : : "When set to 1, entity will not spawn in base Quake III Arena. Ignored in Quake Live." =
	[
		"" : "No"
		1 : "Yes"
	]
	notta(choices) : "Not in Team Arena" : : "When set to 1, entity will not spawn in the Team Arena expansion. Ignored in Quake Live." =
	[
		"" : "No"
		1 : "Yes"
	]
	gametype(string) : "In Game Types" : : "Space delineated list of gametypes that will spawn this entity. If null, it will spawn in all game modes.\nQ3A values: ffa tournament single team ctf.\nQ3TA values: oneflag obelisk harvester teamtournament.\nQL values: ffa duel race tdm ca ctf 1f ob har ft dom ad rr"
	not_gametype(string) : "Not in Game Types (Quake Live)" : : "Quake Live only. Like gametype, but inverted; any gametypes listed here will cause the entity to *not* spawn."
	// Quake Live gametypes: 
	// ffa		(free for all)
	// duel		(duel)
	// race		(race)
	// tdm		(team deathmatch)
	// ca		(clan arena)
	// ctf		(capture the flag)
	// 1f		(one flag)
	// har		(harvester)
	// ft		(freezetag)
	// dom		(domination)
	// ad		(attack & defend)
	// rr		(red rover)
	// name values in Q3A and Q3TA should be more self explantatory
]

@BaseClass = TargetName
[
	targetname(target_source) : "Target Name"
]

@BaseClass = Target
[
	target(target_destination) : "Target"
]

@BaseClass = TargetShader
[
	// can't use "shader" KV type, as it doesn't include the "textures/" prefix
	targetShaderName(string) : "Target Shader Name" : : "Full name of the original shader to remap from (see TargetShader notes in FGD)."
	targetShaderNewName(string) : "Target Shader New Name" : : "Full name of the new shader to remap to (see TargetShader notes in FGD)."
	
	// When the entity activates its targets, all shaders/textures in the map that were originally the same name as the 'targetShaderName' value, will be changed to the 'targetShaderNewName' value. For example, turning a light on:
	// 	"targetShaderName"    "textures/proto2/redlight_off"
	// 	"targetShaderNewName" "textures/proto2/redlight_on"
	// And this would turn it back off:
	// 	"targetShaderName"    "textures/proto2/redlight_off"
	// 	"targetShaderNewName" "textures/proto2/redlight_off"
]

@BaseClass base(TargetName,Target,TargetShader,GameModes) = TargetX []


@BaseClass = Brushwork
[
	// TODO - sift through and find missing KVs
	_lightmapscale(float) : "Lightmap Scale" : "1.0" : "Floating point value, scaling the resolution of lightmaps on brushes/patches in this entity (default 1.0)."
	_indexmap(string) : "Terrain Blending Map" : : "Path/name for the art file used to guide the mapping of textures on the terrain surface."
	_layers(integer) : "Terrain Layers" : : "Number of unique root shaders that will be used on the terrain."
	_shader(shader) : "Terrain MetaShader" : : "Path to the metashader used to assign textures to the terrain entity. Note: Omit the textures/ prefix."
	_celshader(shader) : "Cel Shader" : : "Sets the cel shader used for this geometry. Note: Omit the textures/ prefix."
	_receiveshadows(integer) : "Shadow Receiver Level" : 1 : "Allows per-entity control over shadow reception. Defaults to 1 on everything (world shadows). 0 = receives NO shadows. > 1 = receive shadows only from corresponding keyed entities (see above) and world. < 1 = receive shadows ONLY from corresponding keyed entities."
	_ambient(float) : "Ambient Intensity" :  : "Adds a constant value to overall lighting (default 0, range 0 - 255). Use is not recommended. It has a tendency to flatten out variations in light and shade."
	_color(color1) : "Ambient Color" :  : "RGB color value for ambient and other global light parameters (default is 1 1 1)."
	_minlight(float) : "Min Lightmap Intensity " : : "Minimum light value. If _minvertexlight and _mingridlight are unset, affects vertex colors and lightgrid in additon to lightmap. Uses the _color key to set color. Since it does not add unlike ambient, but overrides existing light values, affected areas will get flat constant light. Not recommended on worldspawn; should be used on specific entities (ex: func_door) that get faces which are going to be inevitably pitch black due to spawning obscured."
	_minvertexlight(float) : "Min Vertex Intensity" : : "Minimum vertex lighting."
	_mingridlight(float) : "Min Dynamic Intensity" : : "Minimum lightgrid (dynamic entity lighting)."
	_floodlight(string) : "Floodlight" : : "A sextet of values r g b dist intensity directional_power to set global floodlight parameters (good defaults are 240 240 255 1024 128 1). Floodlight effect is sort of Ambient Occlusion."
]

@BaseClass base(GameModes, Brushwork) = BModels
[
	_castshadows(integer) : "Shadow Caster Level" : 0 : "Allows per-entity control over shadow casting. Defaults to 0 on entities, 1 on world. 0 = no shadow casting. 1 = cast shadows on world. > 1 = cast shadows on entities with _rs (or _receiveshadows) with the corresponding value, AND world. Negative values imply same, but DO NOT cast shadows on world."
	_targetname(target_source) : "Q3Map2 Internal Name" : : "misc_model's `target` KV prioritizes this over regular targetname, so that entities which have their behavior changed by having a targetname can have baked models."
	model2(studio) : "Aux Model (Model2)" : : "Path/name of model to display (.md3 files only, e.g. models/mapobjects/jets/jets01.md3). This can be useful if this entity is supposed to move or rotate from its original position, as the baked lighting may look weird.\nThe origin point of the model will correspond to the origin point defined by the origin brush. WeapClip brushes should be used for collision."
	light(float) : "Model2 Constant Light" : : "Diameter of constant light of model2, included with entity (default 0, range 0 - 1024)."
	color(string) : "Model2 Constant Color" : : "Color of constant light of model2, included with entity (default 1 1 1)."
	_frame2(integer) : "Q3Map2 Model2 Frame" : : "If set, this frame of model2 will be used for lighting calculations instead of the first frame. Does not affect runtime shadows."
	max(string) : "maxs Vector Override"
	min(string) : "mins Vector Override"
]

@BaseClass base(TargetShader, GameModes) size(-16 -16 -16, 16 16 16) offset(0 0 16) = ItemBase
[
	notbot(choices) : "Invisible To Bots" : : "Used to make an item invisible for bot attraction." =
	[
		"" : "No"
		1 : "Yes"
	]
	// `wait` is set per item type, to permit default autofill
	// ditto for `count`, which is set either per type, or per item
	random(float) : "Respawn Delay Variance" : : "Random time variance in seconds added or subtracted from wait delay (default 0 - see ItemBase notes in FGD)."
	team(string) : "Team Name" : : "Set this to team items. Teamed items will respawn randomly after team master is picked up (see ItemBase notes in FGD)."
	target(target_destination) : "Target" : : "Picking up the item will trigger the entity this points to."
	targetname(target_source) : "Target Name" : : "A target_give entity, pointed to this, gives the item to player. Activating this by other entities will make the item to respawn."
	
	spawnflags(flags) =
	[
		1 : "No Drop To Floor" : 0 : "Item will spawn where it was placed in map and won't drop to the floor."
	]
	
	// The amount of time it takes for an item in the team to respawn is determined by the "wait" value of the item that was picked up previously. So if one of the items in the team has it's "wait" key set to -1 (never respawn), the random respawning cycle of the teamed items will stop after that item is picked up.
	//
	// When the random key is set, its value is used to calculate a minimum and a maximum delay. The final time delay will be a random value anywhere between the minimum and maximum values: (min delay = wait - random) (max delay = wait + random).
]

//
// Editor-only entities
//

@PointClass studio() base(EditorComment) = _editor_model2_visualizer : "Editor-only entity to display a model at an arbitrary location. Designed to visualize model2 for func_ models in-editor. Does not exist in-game, so it doesn't count towards entity limits."
[
	model2(studio) : "Model to display in editor"
	sequence(integer) : "Frame to display" : 0 : "This should match _frame2 of the entity with a model2."
	target(target_destination) : "Entity with model2" : : "Fill this out if you want a line tracing from this entity to the entity it is representing the model2 of."
]

//
// Q3Map2 Entities
//

@SolidClass base(EditorComment) = _decal : "Compiler-only entity that specifies a decal to be projected. Should contain 1 or more patch meshes (curves) and target an info_null entity. Patch mesh should be using a shader with polygonoffset (or other blending methods) or z-fighting will occur. The distance between the center of the _decal entity and the target is the axis and distance of projection."
[
	target(target_destination) : "Target" : : "The name of the entity targeted for projection."
]

@PointClass size(-4 -4 -4, 4 4 4) color(197 225 255) base(EditorComment,Angles) flags(Angle) = _skybox : "Compiler-only entity that specifies the origin of a ''3D skybox'' (a wholly contained, separate area of the map), similar to some games portal skies. When compiled with Q3Map2, the skybox surfaces will be visible from any place where sky is normally visible. It will cast shadows on the normal parts of the map, and can be used with cloud layers and other effects."
[
	angle(integer) : "Yaw" : 0 : "Rotation angle of the sky surfaces."
	_scale(float) : "Scale" : "64" : "Scaling factor (default 64), good values are between 50 and 300, depending on the map."
]

@PointClass size(-16 -16 -16, 16 16 16) color(255 128 64) base(EditorComment,Angles) flags(Angle) studio() = misc_model : "Generic placeholder for inserting models to map. Model triangles are baked to BSP.\n\nSee FGD comment for valid clipping combinations.\n\nMD3, ASE, 3DS, OBJ, FM, LWO, MD2, MDC, MS3D model formats are supported, as well as a whole bunch of other AssImp formats."
[
	model(studio) : "Model File" : : "Path/name of model to use (e.g. models/mapobjects/teleporter/teleporter.md3)."
	//frame(integer) : "Model Frame" : : "Frame of model to load (doesn't work)."
	skin(string) : "Skin" : : "Name of .skin file to load."
	modelscale(scale) : "Uniform Scale" : "1" : "Floating-point value used to scale a model up or down (default 1.0)."
	modelscale_vec(vector) : "Scale XYZ" : : "Floating-point vector used to scale a model's axes individually (default 1.0 1.0 1.0)."
	_remap(string) : "Material Remaps" : : "Used to remap textures/materials in the model. To remap all materials to a given material, use *;models/mymodel/mytexture. To remap a specific material, use models/mymodel/old;models/mymodel/new. Any key starting with _remap prefix will work, so if you need more remappings, create _remap2, _remap3 etc keys."
	target(target_destination) : "Target" : : "Used to attach the misc_model to a brush entity, where its targetname or _targetname key is the same value. If the model moves, model2 should be used if available, as misc_model lighting is prebaked."
	_lightmapscale(float) : "Lightmap Scale" : "1.0" : "Floating point value, scaling the resolution of lightmaps on this model (if model is using lightmapped materials) (default 1.0)."
	_castshadows(integer) : "Shadow Caster Level" : 1 : "Allows per-entity control over shadow casting. Defaults to 0 on entities, 1 on world. 0 = no shadow casting. 1 = cast shadows on world. > 1 = cast shadows on entities with _rs (or _receiveshadows) with the corresponding value, AND world. Negative values imply same, but DO NOT cast shadows on world."
	_receiveshadows(integer) : "Shadow Receiver Level" : 1 : "Allows per-entity control over shadow reception. Defaults to 1 on everything (world shadows). 0 = receives NO shadows. > 1 = receive shadows only from corresponding keyed entities (see above) and world. < 1 = receive shadows ONLY from corresponding keyed entities."
	_clipdepth(float) : "Autoclip thickness" : "2.0" : "Autoclip brushes thickness (default 2.0)."
	_celshader(shader) : "Cel Shader" : : "Sets the cel shader used for this geometry. Note: Omit the textures/ prefix."
	_ambient(float) : "Ambient Light Level"
	_minlight(float) : "Minimum Light Level (minlight)"
	_minvertexlight(float) : "Minimum Vertex Light Level"
	_color(color1) : "Ambient/Minlight Color" : "1 1 1" : "Color to use for _ambient, _minlight, and _minvertexlight"
	_shadeangle(float) : "Smoothing Angle Override" : : "Overrides vertex normals stored in the original model's geometry."
	spawnflags(flags) = 
	[
		1 : "_RMG_BSP" : 0 : "in SoF2, append a _RMG_BSP suffix to shader names instead of _BSP"
		2 : "Clip Model" : 0 : "CLIPMODEL: Clips the model for player/weapon collisions; extruding every face along most perpendicular axial direction. For use on large architectural or terrain models, not for small decorative models."
		4 : "Force Meta" : 0 : "Converts model triangles to BSP metasurfaces; required for lightmapped models.\nIf the model has materials defined a .shader file, use q3map_forceMeta in the material instead."
		8 : "Extrude Face Normals" : 0 : "EXTRUDE_FACE_NORMALS: extrude along the model face normals for clipping"
		16 : "Extrude Terrain" : 0 : "EXTRUDE_TERRAIN: extrude each surface of the model along its average axial direction ( up/down/west/east/north/south ); faces with not matching direction (or too steep) are clipped in default mode"
		32 : "Color to Alpha" : 0 : "COLOR_TO_ALPHA: use the color value as alpha (for terrain blending)"
		128 : "Extrude Vertex Normals" : 0 : "EXTRUDE_VERTEX_NORMALS: extrude along the model vertex normals for clipping; accurate collisions, if normals are fine; bad ones are replaced with 45 degrees to face"
		256 : "Pyramidal Clip" : 0 : "PYRAMIDAL_CLIP: pyramidal clipping brushes (4-sided); accurate collisions"
		512 : "Extrude Downwards" : 0 : "EXTRUDE_DOWNWARDS: for horizontal terrain; when not possible, extrude in default mode"
		1024 : "Extrude Upwards" : 0 : "EXTRUDE_UPWARDS"
		2048 : "Max Extrude" : 0 : "MAX_EXTRUDE: Extrude to the max/min point of every model surface to reduce bsp size (uses axial back plane)"
		4096 : "Axial Backplane" : 0 : "AXIAL_BACKPLANE: use axial back plane for clipping brushes to effectively reduce bsp size; might cause unwanted collisions, make sure to -debugclip; negative _clipdepth / -clipdepth limits max thickness of resulting brushes (making non-axial backplane, if hit the limit)"
		
		// other possible modes of clipping:
		// CLIPMODEL+AXIAL_BACKPLANE
		// EXTRUDE_FACE_NORMALS+PYRAMIDAL_CLIP - truncated pyramid with 45 degrees sides
		// EXTRUDE_TERRAIN+MAX_EXTRUDE
		// EXTRUDE_TERRAIN+AXIAL_BACKPLANE
		// EXTRUDE_VERTEX_NORMALS + PYRAMIDAL_CLIP - vertex normals mode: don't check for sides, sticking outwards
		// PYRAMIDAL_CLIP+AXIAL_BACKPLANE - pyramid with 3 of 4 sides axial (->small bsp)
		// EXTRUDE_DOWNWARDS+EXTRUDE_UPWARDS
		// EXTRUDE_DOWNWARDS+MAX_EXTRUDE
		// EXTRUDE_DOWNWARDS+AXIAL_BACKPLANE
		// EXTRUDE_DOWNWARDS+EXTRUDE_UPWARDS+MAX_EXTRUDE
		// EXTRUDE_DOWNWARDS+EXTRUDE_UPWARDS+AXIAL_BACKPLANE
		// EXTRUDE_UPWARDS+MAX_EXTRUDE
		// EXTRUDE_UPWARDS+AXIAL_BACKPLANE
	]
]

@SolidClass base(EditorComment,Brushwork) = func_group : "This is not an entity as such. It is strictly an editor utility to group world brushes and patches together for convenience (selecting, moving, copying, applying special compilation parameters etc). You cannot group entities with this. Func_group contents are merged into worldspawn entity during compilation process.\n\nTo make a func_group into a terrain entity, refer to the Terrain Construction documentation."
[
	_castshadows(integer) : "Shadow Caster Level" : 1 : "Allows per-entity control over shadow casting. Defaults to 0 on entities, 1 on world. 0 = no shadow casting. 1 = cast shadows on world. > 1 = cast shadows on entities with _rs (or _receiveshadows) with the corresponding value, AND world. Negative values imply same, but DO NOT cast shadows on world."
	
	// == OLD TERRAIN KEYS (Note: Obsolete with Q3Map2; uncomment if using original compilers) ==
	//alphamap(string) : "Alphamap" : : "This is the path/name for the art file used to guide the mapping of textures on the terrain surface."
	//layers(integer) : "Layers" : : "This Integer value denotes number of unique root shaders that will be used on the terrain."
	//shader(shader) : "Metashader" : : "This is the path to the metashader used to assign textures to the terrain entity."
	//terrain(choices) : "Is Terrain" : 1 "This is an on/off flag. When set to 1, the entity becomes a terrain entity. Note: Unnecessary when compiling with Q3Map2. See Q3Map2 keys." =
	//[
	//	0 : "False"
	//	1 : "True"
	//]
]


//
// Lights
//

@BaseClass base(EditorComment) = LightBase
[
	targetname(string) : "Target Name (unused)" : : "Toggled lights are not supported." // for clarity when porting
	light(float) : "Brightness" : 300 : "Overrides the default 300 intensity. Negative values may be used for negative lights."
	_color(color1) : "RGB color" : "1 1 1" : "Weighted RGB value of light color (default 1.0 1.0 1.0 = white)."
	target(target_destination) : "Spotlight Target" : : "Lights pointed at a target (info_null) will be spotlights."
	radius(float) : "Spotlight Radius" : 60 : "Overrides the default 64 unit radius of a spotlight at the target point."
	_sun(choices) : "Spotlight is Sun" : : "Set this key to 1 on a spotlight to make an infinite sun light." =
	[
		"" : "No"
		1 : "Yes"
	]
	fade(float) : "Linear Fade" : "1.0" : "Fades light attenuation. Only affects linear lights."
	scale(float) : "Brightness Scale" : "1.0" : "Scales the light value."
	_deviance(float) : "Penumbra Deviance" : : "Penumbra effect - distance measured in world units for point/spot lights, and degrees for suns (~0.5-3)."
	_samples(integer) : "Penumbra Samples" : 1 : "Penumbra effect - the number of random jitters distributed over the solid arc (~16)."
	_filter(choices) : "Lightmap Filtering" : : "Filter lightmaps from this light, similar to -filter." =
	[
		"" : "No"
		1 : "Yes"
	]
	_filterradius(float) : "Filter Radius" : : "Filters lightmaps within set radius."
	_anglescale(float) : "Light Attenuation Scale" : 1 : "Scales light attenuation. Smaller values lessens angle attenuation, larger values for sharper, more faceted lighting (default 1.0)."
	spawnflags(flags) = 
	[
		1 : "Linear Falloff" : 0 : "Use a linear falloff. Default is inverse distance squared (more realistic), unless -wolf."
		2 : "No Angle Attenuation" : 0 : "Ignore angle attenuation (unless -wolf, in which case enables angle attenuation)."
		16 : "No Grid Light" : 0 : "Do not affect the lightgrid (dynamic entity lighting). If used on lightJunior, causes the light to be inert."
		32 : "unnormalized" : 0 : "Do not normalize light color. Recommended if you don't have at least one color channel that is 1 (color1) or 255 (color255)."
		64 : "Distance attenuation" : 0 : "Use distance attenuation used for sun and area lights (why did vortex add this, this is always set...?)."
	]
]

@PointClass size(-8 -8 -8, 8 8 8) iconsprite("sprites/light.spr") flags(Light) base(LightBase) = light : "Non-displayed point light source. The -pointscale and -scale arguments to Q3Map2 affect the brightness of these lights. The -skyscale argument affects brightness of entity sun lights."
[
	style(integer) : "Lightstyle" : : "Light style index number associated with worldspawn light style. Values are between 1 and 31."	
	_flare(choices) : "Emit default flare" : : "Emit a flare using the default flare material (`flareshader`). Requires -flares in -bsp stage." =
	[
		"" : "No"
		1 : "Yes"
	]
	_flareshader(string) : "Flare Shader" : : "Full path to material to emit flare using. Requires -flares in -bsp stage."
]

@PointClass size(-6 -6 -6, 6 6 6) iconsprite("sprites/light.spr") flags(Light) base(LightBase) = lightJunior : "Non-displayed point light source THAT ONLY AFFECTS ENTITIES (lightgrid). The -pointscale and -scale arguments to Q3Map2 affect the brightness of these lights. The -skyscale argument affects brightness of entity sun lights." []

@PointClass size(-8 -8 -8, 8 8 8) iconsprite("sprites/light.spr") flags(Light) base(light) = light_spot : "All classnames prefixed with `light` except lightJunior act the same as `light`; I just use this separate classname as an alias for clarity." []

