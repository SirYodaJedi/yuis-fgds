@BaseClass base(Angles,GameModes,TargetShader) flags(Angle) size(-16 -16 -24, 16 16 32) offset(0 0 24) = PlayerBase
[
	target(target_destination) : "Target When Spawned At" : : "This can point at a target_give entity for respawn freebies or to anything else to trigger."
	nobots(choices) : "No Bots" : : "When set to 1, bots will never use this spawn point to respawn in the game." =
	[
		"" : "No"
		1 : "Yes"
	]
	nohumans(choices) : "No Humans" : : "When set to 1, human players will never use this spawn point to respawn in the game." =
	[
		"" : "No"
		1 : "Yes"
	]
]

@PointClass base(PlayerBase) color(255 128 0) = info_player_deathmatch : "Normal player spawning location for Q3A levels."
[
	spawnflags(flags) = 
	[
		1 : "initial" : 0 : "Makes the spawnpoint the initial place for the player to spawn at the beginning of the game."
	]
]

@PointClass base(PlayerBase) color(0 255 0) = info_player_start : "Deprecated; acts as alias for info_player_deathmatch."
[
	spawnflags(flags) = 
	[
		1 : "Initial" : 0 : "Makes the spawnpoint the initial place for the player to spawn at the beginning of the game."
	]
]

@PointClass base(PlayerBase) color(0 51 255) = team_CTF_blueplayer : "Initial Blue team spawning position for CTF games. This is where players spawn when they join the Blue team." []
@PointClass base(PlayerBase) color(0 51 255) = team_CTF_bluespawn : "Blue team respawning position for CTF games. This is where Blue team players respawn after they get fragged." []

@PointClass base(PlayerBase) color(255 51 0) = team_CTF_redplayer : "Initial Red team spawning position for CTF games. This is where players spawn when they join the Red team." []
@PointClass base(PlayerBase) color(255 51 0) = team_CTF_redspawn : "Red team respawning position for CTF games. This is where Red team players respawn after they get fragged." []

//
// Shooters
//

@BaseClass base(GameModes) size(-8 -8 -8, 8 8 8) color(255 0 128) flags(Angle) = ShooterBase
[
	// `angle` is commented-out because Jack annoyingly prioritizes it even if empty
	//angle(float) : "Yaw Angle (deprecated)" : : "Yaw aiming angle of shooter."
	targetname(target_source) : "Target Name" : : "Activating trigger points to this."
	angles(angle) : "Pitch Yaw Roll (Y Z X)" : "0 0 0" : "This sets the pitch and yaw aiming angles of shooter (default 0 0). The roll angle does not apply."
	target(target_destination) : "Target to shoot at" : : "This points to a target_position entity for aiming the shooter; takes precedence over `angles`."
	random(float) : "Angle Variance" : 1 : "Random aiming variance in degrees (range 0 - 90, default 1).\n\nWhen the random key is set, its value is used to calculate a maximum angle deviation from the normal trajectory formed by a straight line between the shooter and the aiming entity it targets. The final trajectory will be a random value anywhere between no deviation at all (0) to maximum deviation (value of the random key / 2). Setting random key to 0 won't disable random, setting it to 180, 360, 0.0000001, or 1e-7 will do."
]

@PointClass base(ShooterBase) = shooter_grenade : "This will shoot a grenade each time it's triggered. Aiming is done by setting the `angles` KV or by targeting an info_notnull, target_position or any other entity." []
@PointClass base(ShooterBase) = shooter_plasma : "This will shoot a plasma ball each time it's triggered. Aiming is done by setting the `angles` KV or by targeting an info_notnull, target_position or any other entity." []
@PointClass base(ShooterBase) = shooter_rocket : "This will shoot a rocket each time it's triggered. Aiming is done by setting the angle, `angles` KV or by targeting an info_notnull, target_position or any other entity." []


//
// Target entities
//

// This is here because it's not really a func
@PointClass size(-8 -8 -8, 8 8 8) color(0 102 255) base(TargetX) = func_timer : "Time delay trigger that will continuously fire its targets after a preset time delay. The time delay can also be randomized. When triggered, the timer will toggle on/off."
[
	wait(float) : "Delay between triggerings" : 1 : "Delay in seconds between each triggering of its targets (default 1)."
	random(float) : "Delay variance" : 1 : "Random time variance in seconds added or subtracted from wait delay (default 1).\nWhen the random key is set, its value is used to calculate a minimum and a maximum delay. The final time delay will be a random value anywhere between the minimum and maximum values: (min delay = wait - random) (max delay = wait + random)."
	spawnflags(flags) = 
	[
		1 : "Start On" : 0 : "Timer will start on in the game and continuously fire its targets."
	]
]

@PointClass size(-8 -8 -8, 8 8 8) color(0 179 179) base(TargetX)= target_delay : "Time delay trigger intermediary. Like a target_relay, this can only be fired by other triggers which will cause it in turn to fire its own targets."
[
	wait(float) : "Delay" : 1 : "Delay in seconds from when this gets triggered to when it fires its own targets (default 1)."
	delay(float) : "Delay (deprecated)" : : "Same as wait. For consistency, wait is preferred."
	random(float) : "Delay Variance" : 0 : "Random time variance in seconds added or subtracted from wait delay (default 0).\nWhen the random key is set, its value is used to calculate a minimum and a maximum delay. The final time delay will be a random value anywhere between the minimum and maximum values: (min delay = wait - random) (max delay = wait + random)."
]

@PointClass size(-8 -8 -8, 8 8 8) color(0 128 0) Base(TargetName,GameModes) = target_give : "This is used to give ammo, weapons, health or items to the player who activates it.\n\nThere are 2 ways to use this entity:\na) Automatically give items to players when they spawn in the game: Make a spawn location entity like info_player_deathmatch or CTF respawn, targeting this entity, then target it to the item(s) to give to the player upon respawn.\nb) Give items to players during the game: Make a trigger_multiple/func_button/other_activatable_entity target this entity, then make it target the item(s) to give to the player when the trigger is touched."
[
	// NOTE - this does not actually have the TargetShader stuff, unlike stated in the ENT. It never "uses" its targets.
	target(target_destination) : "Target Item(s) to Give" : : "This points to the item(s) to give when activated. These items aren't respawned in game."
]

@PointClass size(-8 -8 -8, 8 8 8) color(0 128 0) Base(Target,GameModes) = target_kill : "This will ''kill'' the player who activates the trigger that fires this target. (In actuality, it deals 100000 hit points, ignoring protection.)\nUnlike RtCW/ET, this cannot be used to ''killtarget'' entities." []

@PointClass size(-8 -8 -8, 8 8 8) color(0 128 0) flags(Angle) base(TargetName,GameModes) = target_laser : "Toggleable laser beam. Appearance is broken, damage is applied only to movers with health key, so it may be used for logic circuits."
[
	// `angle` is commented-out because Jack annoyingly prioritizes it even if empty
	//angle(float) : "Yaw Angle (deprecated)" : : "Yaw aiming angle of laser."
	angles(angle) : "Pitch Yaw Roll (Y Z X)" : "0 0 0" : "This sets the pitch and yaw aiming angles of laser (default 0 0). The roll angle does not apply."
	target(target_destination) : "Laser Target" : : "Point this to a target_position entity to set the laser's aiming direction. Takes precedence over `angles`."
	dmg(integer) : "Damage" : 5 : "Number of points of damage inflicted per server frame (default 5 - integer values only)."
	spawnflags(flags) = 
	[
		1 : "Start On" : 0 : "When set, the laser will start on in the game."
	]
]

@PointClass size(-8 -8 -8, 8 8 8) color(0 128 0) base(GameModes,TargetName) = target_location : "Location marker used by bots and players for team orders and team chat in the course of Teamplay games. The closest target_location in sight is used for the location. If none is in sight, the closest in distance is used."
[
	message(string) : "Location Name" : "TODO - set location name" : "Name of the location (text string). Displayed in parentheses in front of all team chat and order messages."
	count(choices) : "Color" : : "Color of the location text displayed in parentheses during team chat. Set to 0-7 for color." =
	[
		0 : "White (default)"
		1 : "Red"
		2 : "Green"
		3 : "Yellow"
		5 : "Cyan"
		6 : "Magenta"
		7 : "White"
	]
]

@PointClass size(-8 -8 -8, 8 8 8) color(0 128 0) base(TargetName,GameModes) iconsprite("sprites/dod/envtarget.spr") = target_position : "Aiming target for entities like light, misc_portal_camera and trigger_push (jump pads) in particular. Acts same as info_notnull." []

@PointClass size(-8 -8 -8, 8 8 8) color(0 128 0) base(GameModes,TargetName) = target_print : "This will print a message on the center of the screen when triggered. By default, all clients will see the message."
[
	message(string) : "Message to display" : "TODO - target_print with no message" : "Text string to print on screen."
	spawnflags(flags) = 
	[
		1 : "Red Team Only" : 0 : "Only the red team players will see the message."
		2 : "Blue Team Only" : 0 : "Only the blue team players will see the message."
		4 : "Activator Only" : 0 : "Only the player that activates the target will see the message."
	]
]

@PointClass size(-8 -8 -8, 8 8 8) color(128 128 128) flags(Angle) base(GameModes) = target_push : "This can be used to create jump pads and launch ramps. The direction of push can be set by the `angles` KV or pointing to a target_position or info_notnull entity. Unlike trigger_push, this is NOT client side predicted and must be activated by a trigger.\n\nTo make a jump pad or launch ramp, create a trigger_multiple where the jump must originate. Place the target_push directly above the trigger_multiple and place the target_position entity at the highest point of the jump. Target the trigger_multiple to the target_push and target the target_push to the target_position/info_notnull (or set the target_push's `angles` KV). Note, that, when using aiming by target_position, it MUST be located higher, than target_push, while in `angles` scenario player may be pushed downwards too."
[
	// `angle` is commented-out because Jack annoyingly prioritizes it even if empty
	//angle(float) : "Yaw Angle (deprecated)" : : "Yaw aiming angle of push entity."
	angles(angle) : "Pitch Yaw Roll (Y Z X)" : "0 0 0" : "This sets the pitch and yaw aiming angles of push entity (default 0 0). The roll angle does not apply."
	speed(float) : "Push Speed" : 1000 : "Speed of push (default 1000). Has no effect if entity targets an aiming entity."
	target(target_destination) : "Push Target" : : "This points to the aiming entity to which the player will jump. Takes precedence over `angles`."
	targetname(target_source) : "Target Name" : : "The activating trigger points to this. Push originates from the location of the trigger."
	spawnflags(flags) = 
	[
		1 : "Bounce Pad" : 1 : "If set, trigger will play `sound/world/jumppad.wav` instead of `sound/misc/windfly.wav` noise when activated (recommended, as windfly is missing in a vanilla installation, so it would need to be included in your PK3).\nQuake Live doesn't play any sound at all if this spawnflag is unchecked."
	]
]

@PointClass size(-8 -8 -8, 8 8 8) color(0 179 179) base(TargetX) = target_relay : "This can only be activated by other triggers which will cause it in turn to activate its own targets."
[
	spawnflags(flags) = 
	[
		1 : "Red Team Only" : 0 : "Only red team players can activate trigger."
		2 : "Blue Team Only" : 0 : "Only blue team players can activate trigger."
		4 : "Random Target" : 0 : "One of the targeted entities will be triggered at random."
	]
]

@PointClass size(-8 -8 -8, 8 8 8) color(0 179 179) base(TargetName,GameModes) = target_remove_powerups : "This takes away any and all item_* type powerups from player except health and armor (holdable_* items are not taken away either). Must be activated by a button or trigger_multiple entity. The player that activates the trigger will lose any powerup(s) currently in his possession." []

@PointClass size(-8 -8 -8, 8 8 8) color(0 128 0) base(TargetName,GameModes) = target_score : "This is used to automatically give frag points to the player who activates this. A spawn location entity like info_player_* or CTF respawn points can target this entity to give points to the player when he spawns in the game. Or a trigger can also be used to activate this. The activator of the trigger will get the points."
[
	count(integer) : "Frags Given" : 1 : "Number of frag points to give to player (default 1)."
]

@PointClass size(-8 -8 -8, 8 8 8) color(0 179 179) base(TargetName,GameModes) iconsprite("sprites/speaker.spr") = target_speaker : "`Sound generating entity that plays .wav files. Normal non-looping sounds play each time the target_speaker is triggered. Looping sounds can be set to play by themselves (no activating trigger) or be toggled on/off by a trigger.\n\nThe combination of the `wait` and `random` keys can be used to play non-looping sounds without requiring an activating trigger but both keys must be used together. The value of the `random` key is used to calculate a minimum and a maximum delay. The final time delay will be a random value anywhere between the minimum and maximum values: (min delay = wait - random) (max delay = wait + random).`\n\nUnlike Quake I+II, looping is handled purely via entity code; loop cues in the WAV are not parsed."
[
	noise(sound) : "Sound File" : : "Path/name of .wav file to play (e.g. `sound/world/growl1.wav` - see notes). Must be mono.\n\nWAV file extension will be automatically applied unless present, even if another file extension is present, except in Spearmint. This means that using `filename.ogg` will load `filename.ogg.wav` in vanilla, but `filename.ogg` proper in Spearmint.\n`developer 1` will complain in the console if the sound is 8-bit and/or isn't 22050 Hz, but 8-bit WAVs and 44100 Hz or 11025 Hz WAVs are completely allowed (there even are vanilla sounds that break the rules).\n\nThe path portion value of the `noise` key can be replaced by the implicit folder character `*` for triggered sounds that belong to a particular player model. For example, if you want to create a ''bottomless pit'' in which the player screams and dies when he falls into, you would place a trigger_multiple over the floor of the pit and target a target_speaker with it. Then, you would set the `noise` key to `*falling1.wav`. The * character means the current player model's sound folder. So if your current player model is Visor, * = sound/player/visor, if your current player model is Sarge, * = sound/player/sarge, etc. This cool feature provides an excellent way to create ''player-specific'' triggered sounds in your levels."
	random(float) : "Repeat Variance" : : "Random time variance in seconds added or subtracted from wait delay (wait key must be set - see notes)."
	wait(float) : "Delay before allowed to repeat" : : "Delay in seconds between each time the sound is played (random key must be set - see notes)."
	spawnflags(flags) = 
	[
		1 : "Loop, Start On" : 0 : "Sound will loop and initially start on in level (will toggle on/off when triggered)."
		2 : "Loop, Start Off" : 0 : "Sound will loop and initially start off in level (will toggle on/off when triggered)."
		4 : "No Distance Attenuation" : 0 : "Sound will play full volume throughout the level."
		8 : "Audible Only To Activator" : 0 : "Sound will play only for the player that activated the speaker."
	]
]

@PointClass size(-8 -8 -8, 8 8 8) color(0 128 0) base(TargetName,GameModes) = target_teleporter : "Activating this will teleport players to the location of the targeted misc_teleporter_dest entity. Unlike trigger_teleport, this entity must be activated by a trigger and does NOT allow client prediction of events."
[
	target(target_destination) : "Teleporter Destination" : : "This must point to a misc_teleporter_dest entity."
]

// This is here because it's not really a trigger
@PointClass size(-8 -8 -8, 8 8 8) color(128 128 128) base(TargetX) = trigger_always : "Automatic trigger. It will fire the entities it targets as soon as it spawns in the game.\n\nThe ''always'' part of the classname is a misnomer, as it isn't constantly firing, and is still affected by the usual game mode KVs; treat it like trigger_auto/target_auto." []

//
// Triggers
//

@SolidClass base(TargetName,GameModes) = trigger_hurt : "Any player that touches this will be hurt by dmg points of damage once per server frame (very fast). A sizzling sound is also played while the player is being hurt.\n\nTriggering a trigger_hurt will have no effect if the START_OFF spawnflag is not set."
[
	dmg(integer) : "Damage Inflicted" : 5 : "Number of points of damage inflicted to player per server frame (default 5 - integer values only)."
	spawnflags(flags) = 
	[
		1 : "Start Disabled" : 0 : "Needs to be triggered (toggle) for damage."
		// TODO confirm - ENT claims "A trigger_hurt always starts on in the game." If so, what does spawnflag 1 do? It's clearly parsed by the spawn function.
		2 : "Toggleable" : 0 : "Allows trigger_hurt to be toggled on/off."
		4 : "Silent" : 0 : "Suppresses the sizzling sound while player is being hurt."
		8 : "No Power-Up Protection" : 0 : "Player will be hurt regardless of protection. The invulnerability power-up (item_enviro) does not protect the player from damage caused by this entity regardless of whether this spawnflag is set or not."
		16 : "Damage Once Per Second" : 0 : "Changes the damage rate to once per second."
	]
]

@SolidClass base(TargetX) = trigger_multiple : "Variable size repeatable trigger. It will fire the entities it targets when touched by player. Can be made to operate like a trigger_once entity by setting the `wait` key to -1. It can also be activated by another trigger that targets it."
[
	wait(float) : "Delay Before Retriggerable" : : "Time in seconds until trigger becomes re-triggerable after it's been touched (default 0.5, -1 = trigger once)."
	random(float) : "Retriggerability Variance" : : "Random time variance in seconds added or subtracted from wait delay (default 0). When the random key is set, its value is used to calculate a minimum and a maximum delay. The final time delay will be a random value anywhere between the minimum and maximum values: (min delay = wait - random) (max delay = wait + random)."
	spawnflags(flags) = 
	[
		1 : "Red Team Only" : 0 : "Only may be triggered by red team."
		2 : "Blue Team Only" : 0 : "Only may be triggered by blue team."
	]
]

@SolidClass base(TargetName,GameModes) = trigger_push : "This is used to create jump pads and launch ramps. It MUST point to a target_position or info_notnull entity, located above trigger's origin, to work (angles KV is not supported). Unlike target_push, this is client side predicted.\n\nTo make a jump pad or launch ramp, place the target_position/info_notnull entity at the highest point of the jump and target it with this entity."
[
	target(target_destination) : "Jump Target" : : "This points to the target_position to which the player will jump."
]

@SolidClass base(TargetName,GameModes)  = trigger_teleport : "Touching this will teleport players to the location of targeted entity. Allows client side prediction of teleportation events."
[
	target(target_destination) : "Teleporter Destination" : : "This must point to a misc_teleporter_dest entity."
]

