//
// Func entities
//

@SolidClass base(TargetName,BModels) = func_bobbing : "Solid entity that oscillates back and forth in a linear motion. By default, it will have an amount of displacement in either direction equal to the dimension of the brush in the axis in which it's bobbing. Entity bobs on the Z axis (up-down) by default. It can also emit sound if the ''noise'' key is set. Will crush the player when blocked."
[
	speed(float) : "Bob Cycle Time" : 4 : "Amount of time in seconds for one complete oscillation cycle (default 4)."
	height(float) : "Vertical Travel" : 32 : "Sets the amount of travel of the oscillation movement (default 32)."
	phase(float) : "Bob Cycle Phase" : 0 : "Sets the start offset of the oscillation cycle. Values must be 0 < phase < 1. Any integer phase value is the same as no offset (default 0)."
	// TODO - dmg not in ENT; confirm it works
	dmg(integer) : "Damage Inflicted" : 2 : "Damage to inflict on players whom block movement of this entity (default 2)."
	noise(sound) : "Sound File" : : "Path/name of .wav file to play. Use looping sounds only (e.g. sound/world/drone6.wav).\nIn order for the sound to be emitted from the entity, it is recommended to include a brush with an origin shader at its center, otherwise the sound will not follow the entity as it moves."
	spawnflags(flags) = 
	[
		1 : "X Axis" : 0 : "Entity will bob along the X axis."
		2 : "Y Axis" : 0 : "Entity will bob along the Y axis."
	]
]

@SolidClass base(BModels,TargetShader) = func_button : "When a button is touched by a player, it moves in the direction set by the `angles` key, triggers all its targets, stays pressed by an amount of time set by the `wait` key, then returns to it's original position where it can be operated again."
[
	// `angle` is commented-out because Jack annoyingly prioritizes it even if empty
	//angle(float) : "Yaw Angle (deprecated)" : : "Determines the direction in which the button will move (up = -1, down = -2)."
	angles(angle) : "Pitch Yaw Roll (Y Z X)" : "0 0 0" : "Pitch and yaw moving direction angles of button (default 0 0). The roll angle does not apply."
	target(target_destination) : "Target" : : "All entities with a matching targetname will be triggered."
	targetname(target_source) : "Target Name" : : "If set, other entities can be used to activate the button along with touch or damage way of doing this."
	speed(float) : "Move Speed" : 40 : "Speed of button's displacement (default 40, -1 = reach the end of move instantly)."
	wait(float) : "Return Delay" : 1 : "Number of seconds button stays pressed (default 1, -1 = return immediately)."
	lip(float) : "Lip + 2" : 4 : "Lip remaining at end of move. Default value is 4, which results in 2u of physical lip. I.e. for wished amount of move set key to [size + 2 - amount], 2 for full move, [size + 2] for none."
	health(choices) : "Activate On Damage" : 0 : "If set to any non-zero value, the button must take damage (any amount) to activate (default 0)." =
	[
		0 : "No"
		1 : "Yes"
	]
]

@SolidClass base(BModels,TargetShader) = func_door : "Normal sliding door entity. By default, the door will activate when player walks close to it or when damage is inflicted to it."
[
	// `angle` is commented-out because Jack annoyingly prioritizes it even if empty
	//angle(float) : "Yaw Angle (deprecated)" : : "Determines the opening direction of door (up = -1, down = -2)."
	angles(angle) : "Pitch Yaw Roll (Y Z X)" : "0 0 0" : "Pitch and yaw moving direction angles of door (default 0 0). The roll angle does not apply."
	target(target_destination) : "Target When Opened" : : "Fired when the door opens; but not *not* when it closes."
	targetname(target_source) : "Target Name" : : "If set, a func_button or trigger is required to activate the door (unless using health key)."
	speed(float) : "Move Speed" : 400 : "Determines how fast the door moves (default 400, -1 = reach the end of move instantly)."
	wait(float) : "Return Delay" : 2 : "Number of seconds before door returns (default 2, -1 = return immediately)"
	lip(float) : "Lip + 2" : 8 : "Lip remaining at end of move. Default value is 8, which results in 6u of physical lip. I.e. for wished amount of move set key to [size + 2 - amount], 2 for full move, [size + 2] for none."
	health(choices) : "Activate On Damage" : 0 : "If set to any non-zero value, the button must take damage (any amount) to activate (default 0)." =
	[
		0 : "No"
		1 : "Yes"
	]
	dmg(integer) : "Damage Inflicted" : 2 : "Damage to inflict on players whom block operation of door (default 2). Door will reverse direction when blocked unless CRUSHER spawnflag is set."
	team(string) : "Team" : : "Assign the same team name to multiple doors that should operate together. Unlike Quake I+II, doors that touch are NOT automatically teamed."
	spawnflags(flags) = 
	[
		1 : "Start Open" : 0 : "The door will spawn in the open state and operate in reverse."
		4 : "Crusher" : 0 : "Door will not reverse direction when blocked and will keep damaging players until they die or get out of the way."
		16 : "Need Silver Key (Quake Live)" : 0 : "Quake Live only: require item_key_silver or item_key_master to open this door. Takes precedence over targetname and health."
		32 : "Need Gold Key (Quake Live)" : 0 : "Quake Live only: require item_key_gold or item_key_master to open this door. Takes precedence over targetname and health."
	]
]

@SolidClass base(TargetName, BModels) = func_pendulum : "Solid entity that describes a pendulum back and forth rotation movement. Rotates on the X axis by default. Pendulum frequency is a physical constant based on the height of the entity and gravity. Blocking the pendulum instantly kills a player\n\nYou need to have an origin brush (textured by common/origin) as part of this entity. The center of that brush will be the point through which the rotation axis passes."
[
	// `angle` is commented-out because Jack annoyingly prioritizes it even if empty
	//angle(float) : "Yaw Angle (deprecated)" : : "Angle offset of axis of rotation from default X axis (default 0)."
	angles(angle) : "Pitch Yaw Roll (Y Z X)" :  : "Pitch, yaw and roll offsets of axis of rotation from default X axis (default 0 0 0)."
	speed(float) : "Max Swing Angle" : 30 : "Angle of swing arc in either direction from initial position (default 30)."
	phase(float) : "Swing Phase" : 0 : "Sets the start offset of the swinging cycle. Values must be 0 < phase < 1. Any integer phase value is the same as no offset (default 0)."
	noise(sound) : "Sound File" : : "Path/name of .wav file to play. Use looping sounds only (e.g. sound/world/drone6.wav)."
]

@SolidClass base(BModels,TargetShader) = func_plat : "Rising platform the player can ride to reach higher places. Plats must always be drawn in the raised position, so they will operate and be lighted correctly but they spawn in the lowered position (which equals to behavior of func_door with START_OPEN flag set). The plat will stay in the raised position until the player steps off."
[
	speed(float) : "Move Speed" : 200 : "Determines how fast the plat moves (default 200, -1 = reach the end of move instantly)."
	lip(float) : "Lip + 2" : 8 : "Lip remaining at start of move. Default value is 8, which results in 6u of physical lip. I.e. for wished amount of move set key to [size + 2 - amount], 2 for full move, [size + 2] for none. Has no effect if height is set."
	height(float) : "Vertical Travel Height" : 0 : "Sets the total amount of vertical travel of the plat. Negative values will travel downward. It's convenient alternative to lip key (overrides one)."
	dmg(integer) : "Damage Inflicted" : 2 : "Damage to inflict on players whom block operation of plat (default 2). Plat will reverse direction when blocked."
	target(target_destination) : "Target When Raised" : : "Fired when the plat goes to rasied position; but not *not* when returning to its lowered position."
	targetname(target_source) : "Target Name" : : "If set, the trigger that points to this will raise the plat each time it fires. The plat raises and comes back down a second later if no player is on it."
]

@SolidClass base(TargetName,BModels) = func_rotating : "Solid entity that rotates continuously. Rotates on the Z axis by default and requires an origin brush. It will always start on in the game and is not targetable.\n\nYou need to have an origin brush (textured by common/origin) as part of this entity. The center of that brush will be the point through which the rotation axis passes. It will rotate along the Z axis by default. You can check either the X_AXIS or Y_AXIS box to change that."
[
	speed(float) : "Rotation Speed" : 100 : "Determines how fast entity rotates (default = 100 degrees per second)."
	noise(sound) : "Sound File" : : "Path/name of .wav file to play. Use looping sounds only (e.g. sound/world/drone6.wav)."
	// TODO - dmg not in ENT; confirm it works
	dmg(integer) : "Damage Inflicted" : 2 : "Damage to inflict on players whom block movement of this entity (default 2)."
	spawnflags(flags) = 
	[
		4 : "X Axis" : 0 : "Entity will rotate along the X axis."
		8 : "Y Axis" : 0 : "Entity will rotate along the Y axis."
	]
]

@SolidClass base(TargetName,BModels) = func_static : "Static bspmodel. Can be used for conditional walls and models. Like func_wall in Quake I+II.\n\nBecause the map has only a single bot navigation file, func_static cannot be used to make significant changes in game play flow between differing game types."
[
	// TODO confirm - ENT said this; seems BS, based upon source code.
	// "If a model is included with a targeted func_static, the brush(es) of the entity will be removed from the game but the .md3 model won't: It will automatically be moved to the (0 0 0) world origin so you should NOT include an .md3 model to a targeted func_static."
]

@SolidClass base(TargetName,BModels) = func_train : "Trains are moving solids that follow a looped string of path_corner entities. Trains in Q3A are very basic, they also REQUIRE AN ORIGIN BRUSH.\n\n1. Trains always start on in the game.\n2. Trains do not damage the played when blocked.\n3. Trains cannot emit sound.\n4. Trains are not triggerable or toggleable.\n5. Trains cannot be block-stopped just by getting in their way, the player must be wedged between the train and another obstacle to block it."
[
	speed(float) : "Initial Speed" : 100 : "Speed of displacement of train (default 100 or overridden by speed value of path)."
	target(target_destination) : "First Stop Target" : : "The name of the first path_corner in the train's path. The train will spawn at this path_corner."
]

//
// Info entities
//

@PointClass size(-8 -8 -8, 8 8 8) color(0 128 0) base(TargetName,GameModes) = info_camp : "This attracts bots which have a camping preference in their AI characteristics. It should be placed at least 32 units away from any brush surface.\n\nExamples of bots which have a high camping preference are: Razor, Tank Jr., Grunt, Patriot and Doom.\nExamples of bots which have a low camping preference are: Klesk, Mynx, Sarge, Keel and Xaero."
[
	range(float) : "Range" : : "Number of units that the bot can move away from camp entity while camping on it."
	weight(float) : "Weight" : : "Number that is compared against the weight assigned to all the other camp spots in the map to determine if a bot chooses to camp there. The value is normalized against all other weight values."
]

@PointClass size(-8 -8 -8, 8 8 8) color(0 128 0) base(TargetName,GameModes) iconsprite("sprites/dod/envtarget.spr") = info_notnull : "Used as a positional target for entities that can use directional pointing. A target_position can be used instead of this but was kept in Q3A for legacy purposes." []

@PointClass size(-8 -8 -8, 8 8 8) color(0 128 0) base(TargetName,EditorComment) = info_null : "Used as a positional target for light entities to create a spotlight effect. Deleted immediately in its spawn function, so it should never count towards entity limits." []

@PointClass size(-16 -16 -16, 16 16 16) color(255 0 255) flags(Angle) iconsprite("sprites/camera.spr") base(GameModes) = info_player_intermission : "Camera for intermission screen between matches. This also automatically generates the podium for bot arena matches (see notes). Can be aimed by setting the `angles` key or by targeting an aiming entity. Use only one per level.\n\nIn genuine bot arena matches, the podium for the 1st, 2nd and 3rd place players at the end of the match is generated by this entity. The podium's origin will automatically be located 128 units in the direction of the camera's view and 84 units down from the y height of the view line at that point. It will also always be generated on a level plane regardless of the pointing angle of the camera so if that angle is too steep, part of the podium model might not be visible. Make sure you leave at least 106 units of free space in front of where the camera points to otherwise the podium model won't be visible at all."
[
	// `angle` is commented-out because Jack annoyingly prioritizes it even if empty
	//angle(float) : "Yaw Angle (deprecated)" : : "Yaw angle of sight direction."
	angles(angle) : "Pitch Yaw Roll (Y Z X)" : "0 0 0" : "Orientation of camera, if target is absent (default 0 0 0)."
	target(target_destination) : "Camera Target" : : "Point this to an info_notnull or target_position entity to set the camera's pointing angles."
]

//
// Misc entities
//

@PointClass size(-8 -8 -8, 8 8 8) color(255 128 64) flags(Angle) base(GameModes) iconsprite("sprites/camera.spr") = misc_portal_camera : "Portal camera. This camera is used to project its view onto a portal surface in the level through the intermediary of a misc_portal_surface entity. Use the `angles` KV or target a target_position or info_notnull entity to set the camera's pointing direction.."
[
	// `angle` is commented-out because Jack annoyingly prioritizes it even if empty
	//angle(float) : "Yaw Angle (deprecated)" : : "Yaw aiming angle of the portal camera (default 0)."
	angles(angle) : "Pitch Yaw Roll (Y Z X)" : "0 0 0" : "This sets the pitch and yaw aiming angles of the portal camera (default 0 0). Use roll key to set roll angle."
	roll(float) : "Roll Angle" : : "Roll angle of camera. For axial directions a value of 0 is upside down and 180 is the same as the player's view. For other sorts of directions values of 90 and -90 may work (inconsistent math). Irrelevant if either of the rotation spawnflags are enabled."
	target(target_destination) : "Camera Target" : : "Point this to a target_position entity to set the camera's pointing direction. Roll KV is still required."
	targetname(target_source) : "Target Name" : : "A misc_portal_surface portal surface indicator must point to this."
	spawnflags(flags) = 
	[
		1 : "Rotate Slowly" : 0 : "Makes the portal camera rotate slowly along the roll axis."
		2 : "Rotate Faster" : 0 : "Makes the portal camera rotate faster along the roll axis."
		4 : "No Wobble" : 0 : "Stops the camera portal from wobbling."
	]
]

@PointClass size(-8 -8 -8, 8 8 8) color(255 128 64) base(GameModes) = misc_portal_surface : "Portal surface indicator. This will ''lock on'' the brush face closest to it and identify as a portal. The view displayed on the portal surface is the view of the misc_portal_camera that this entity targets. Also used for mirrors.\n\nThe entity must be no farther than 64 units away from the portal surface to lock onto it.\nTo make a mirror, apply the `common/mirror` shader to the surface, place this entity near it but don't target a misc_portal_camera.\nTo make a portal, you need to use a shader with `alphagen portal`, for instance `textures/sfx/portal_sfx`."
[
	target(target_destination) : "Target misc_portal_camera" : : "Point this to a misc_portal_camera that sees the view you want to display on the portal."
]

// originally color(255 128 64); changed to be more distinct from deathmatch spawns
@PointClass size(-16 -16 -24, 16 16 32) offset(0 0 24) color(170 0 255) flags(Angle) base(TargetName,Angles,GameModes) = misc_teleporter_dest : "Teleport destination location point for trigger_teleporter and target_teleporter entities. Angles dictate facing direction.\n\nTechnically, any runtime entity can be used, but using this entity helps with clarity for hull size and angles." []

//
// Paths
//

@PointClass size(-8 -8 -8, 8 8 8) color(128 77 0) base(GameModes,TargetShader) = path_corner : "Path corner entity that func_trains can be made to follow."
[
	target(target_destination) : "Next path_corner & Target" : : "Point to next path_corner in the path and optionally to an entity to trigger, when train reaches this entity."
	targetname(target_source) : "Target Name" : : "The train following the path or the previous path_corner in the path points to this."
	speed(float) : "New Speed" : : "Speed of func_train while moving to the next path corner. This will override the speed value of the train."
	wait(float) : "Corner Delay" : 0 : "Number of seconds func_train will pause on path corner before moving to next path corner (default 0).\nSetting to -1 will NOT make the train stop on the path corner, it will simply default to 0."
]

