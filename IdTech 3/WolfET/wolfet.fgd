@PointClass size(-8 -8 -8, 8 8 8) color(0 128 0) = _null : "Alternative to info_null that will only be recognized by Q3Map2 and will be ignored by the game. Avoids running into entity limits at map spawn due to ET keeping info_null around for an extra tick if named (aren't all info_nulls named?)" []

@SolidClass = _decal : "Compiler-only entity that specifies a decal to be projected. Should contain 1 or more patch meshes (curves) and target an info_null entity. The distance between the center of the _decal entity and the target is the axis and distance of projection."
[
	target(target_destination) : "Target" : : "the name of the entity targeted at for projection"
]

@PointClass size(-4 -4 -4, 4 4 4) color(197 225 255) flags(Angle) = _skybox : "Compiler-only entity that specifies the origin of a skyroom (a wholly contained, separate area of the map), similar to the props_skyportal skies. When compiled with Q3Map2, the skyroom surfaces will be visible from any place where sky is normally visible. It will cast shadows on the normal parts of the map, and can be used with cloud layers and other effects. Unlike props_skyportal, the player cannot elect to switch it off with r_fastsky."
[
	angle(float) : "Yaw angle (Z)" : : "rotation angle of the sky surfaces."
	angles(string) : "Pitch Yaw Roll (Y Z X)" : : "Individual control of PITCH, YAW, and ROLL (default 0 0 0)."
	_scale(float) : "Scale" : "64.0" : "scaling factor (default 64), good values are between 50 and 300, depending on the map."
]

@BaseClass = Q3Map2_Model
[
	_lightmapscale(float) : "Lightmap Scale" : : "Floating point value scaling the resolution of lightmaps on brushes/patches in this entity (default 1.0)."
	_castshadows(integer) : "Shadow Caster Level" : : "Allows per-entity control over shadow casting. Defaults to 0 on entities, 1 on world. 0 = no shadow casting. 1 = cast shadows on world. > 1 = cast shadows on entities with _rs (or _receiveshadows) with the corresponding value, AND world. Negative values imply same, but DO NOT cast shadows on world."
	_receiveshadows(integer) : "Shadow Receiver Level" : : "Allows per-entity control over shadow reception. Defaults to 1 on everything (world shadows). 0 = receives NO shadows. > 1 = receive shadows only from corresponding keyed entities (see above) and world. < 1 = receive shadows ONLY from corresponding keyed entities."
	_celshader(shader) : "Cel Shader Material" : : "Sets the cel shader material used for this geometry. Note: omit the textures/ prefix."
	_shadeangle(float) : "Smoothing angle" : : "Maximum angle to allow smoothing on; default 180.0 unless defined in q3map_shadeAngle"
]

@BaseClass = Q3Map2_Terrain // terrain-related stuff that doesn't need to be shown in every bmodel entity
[
	_indexmap(string) : "Terrain Blending Map" : : "Path/name for the art file used to guide the mapping of textures on the terrain surface."
	_layers(integer) : "Terrain Layers" : : "Integer value is the number unique root shaders that will be use on the terrain."
	_shader(shader) : "Terrain MetaShader" : : "Path to the MetaShader used to assign textures to the terrain entity. Note: Omit the textures/ prefix."
]

@BaseClass base(Q3Map2_Model) = Q3Map2_Bmodel
