@SolidClass base(TargetName, Model2, Q3Map2_Bmodel) = func_pendulum : "Swings like a pendulum. You need to have an origin brush as part of this entity.\n\nPendulums always swing north/south on unrotated models; add an angles field to the model to allow rotation in other directions.\n\nPendulum frequency is a physical constant based on the length of the beam and gravity."
[
	speed(float) : "Arc (degrees)" : 30 : "The number of degrees each way the pendulum swings in each direction"
	phase(float) : "Phase" : : "The 0.0 to 1.0 offset in the cycle to start at"
	dmg(integer) : "Damage when blocked" : 2 : "Damage to inflict when blocked (2 default)"
	angles(angle) : "Pitch Yaw Roll" : : "Specify Pitch/Yaw/Roll for the pendulum to swing in a different direction to the default north-south"
]

@SolidClass base(TargetName, Model2, Q3Map2_Bmodel) = func_plat : "An elevator/lift. Plats should be constructed in the raised position so they will behave and light correctly."
[
	lip(integer) : "Lip" : 8 : "Default 8, protrusion above rest position at solid brush"
	height(integer) : "Travel Altitude" : : "The vertical distance from the starting position that this platform moves. Defaults to model height."
	speed(float) : "Speed" : "200" : "Overrides default 200 movement speed"
	dmg(integer) : "Damage when blocked" : 2 : "Damage caused to blocking player"
]

@SolidClass base(TargetName, Model2, Q3Map2_Bmodel) = func_rotating : "A rotating bmodel. You need to have an origin brush as part of this entity.\n\nThe center of that brush will be the point around which it is rotated.\n\nIt will rotate around the Z axis by default."
[
	speed(float) : "Rotation Speed" : "100" : "determines how fast entity rotates (default 100)."
	dmg(integer) : "Damage when blocked" : 2 : "Damage to inflict when blocked (2 default)"
	spawnflags(flags) = 
	[
		1 : "Start on" : 0 : "Start rotating upon map load."
		2 : "Start invisible" : 0 : "Start the entity as non-existent. If targeted, it will toggle existence when triggered"
		4 : "X axis" : 0 : "entity will rotate along the X axis instead of the Z axis."
		8 : "Y axis" : 0 : "entity will rotate along the Y axis instead of the Z axis."
	]
]

@SolidClass base(TargetName, Model2, Q3Map2_Bmodel) = func_static : "A brush model that just sits there, doing nothing.\n\nCan be used for conditional walls and models."
[
	spawnflags(flags) = 
	[
		1 : "Start invisible" : 0 : "Start the entity as non-existent. If targeted, it will toggle existence when triggered"
	]
]

@PointClass size(-8 -8 -8, 8 8 8) color(77 26 153) base(TargetKVs) = func_timer : "This should be renamed trigger_timer...\n\nRepeatedly fires its targets.\n\nCan be turned on or off by by using.\n\nSo, the basic time between firing is a random time between (wait - random) and (wait + random)"
[
