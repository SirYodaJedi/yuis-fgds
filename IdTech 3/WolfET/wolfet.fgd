@BaseClass = Worldspawn_Base
[
	// important worldspawn KVs, to put before regular Q3Map2 brush KVs
	music(sound) : "Ambient music track" : : "Music file (Uncompressed WAV in vanilla; ETLegacy also supports Ogg Vorbis)"
	_ambient(float) : "Ambient light level" : : "Adds a constant value to overall lighting. Use is not recommended. Ambient light will have a tendency to flatten out variations in light and shade."
	color(color1) : "Ambient light color" : : "RGB value for ambient light color (default is 0 0 0)."
	gravity(float) : "Gravity" : "800" : "Gravity of level (default is normal gravity: 800)."
	gridsize(string) : "Dynamic Light Granularity" : "128 128 256" : "Granularity of the lightgrid created by q3map. Value is three integers separated by spaces, representing number of units between grid points in X Y Z. Default gridsize value is 128 128 256. Use larger powers of 2 to reduce BSP size and compile time on very large maps."
	_blocksize(integer) : "BSP Block Size" : 1024 : "q3map always splits the BSP tree along the planes X=_blocksize*n and Y=_blocksize*n. Default _blocksize value is 1024. Increase the blocksize using larger powers of 2 to reduce compile times on very large maps with a low structural brush density."
	message(string) : "Logon message" : : "Text to print during connection process. Name of the map"
	sun(string) : "Sun material" : : "''Shader'' material to use for ''sun'' image. May be overridden by shader."
	fog(string) : "Fog material" : : "If set, the whole map will be fogged using the given material."
	fogclip(float) : "Fog clipping distance" : : "Uses vis to exclude stuff beyond the specified distance."
	cclayers(integer) : "ccLayers" : 0 // TODO - idk what this does, but it's in the source code
	mapcoordsmins(string) : "Minimap top-left corner (X Y)" : "-128 128" : "Top left corner coordinate. Example -256 256."
	mapcoordsmaxs(string) : "Minimap lower-right corner (X Y)" : "128 -128" : "Lower right corner coordinate. Example 256 -256. Both mapcoordsmins and mapcoordsmaxs must be set for command map and auto map to work properly."
	spawnflags(flags) = 
	[
		1 : "Not for Campaign" : 0 : "Campaign cannot be played on this map"
		2 : "Not for Stopwatch" : 0 : "Stopwatch cannot be played on this map"
		8 : "Not for Last Man Standing" : 0 : "Last Man Standing cannot be played on this map"
	]
]

