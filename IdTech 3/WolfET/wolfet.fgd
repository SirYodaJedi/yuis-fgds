[
	angle(angle) : Angle : : "direction in which player will look when teleported."
	targetname(target_source) : Name : : "make the trigger_teleporter point to this."
]
@PointClass size(-8 -8 -8, 8 8 8) color(200 0 200) = target_print : "This will print a message on the center of the screen when triggered. By default, all the clients will see the message."
[
	message(string) : Message : : "text string to print on screen."
	targetname(target_source) : Name : : "the activating trigger points to this."
	spawnflags(flags) = 
	[
		1 : "axis_only" : 0 : "only the axis players will see the message."
		2 : "allied_only" : 0 : "only allied team players will see the message."
		4 : "private" : 0 : "only the player that activates the target will see the message."
	]
]
