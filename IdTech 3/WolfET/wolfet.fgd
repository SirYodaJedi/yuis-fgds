	[
		1 : "axis" : 0
		2 : "allied" : 0
	]
]

@SolidClass base(ScriptName) studio("models/mapobjects/electronics/alarmbox.md3") = alarm_box : "A triggerable alarm. You need to have an origin brush as part of this entity\n\ncurrent alarm box model is (8 x 16 x 28)\n\ntarget a box to dlights to have them activate/deactivate with the system (use a stylestring that matches the cycletime for the alarmbox sound)\n\nalarm sound locations are also placed in the dlights, so wherever you place an attached dlight, you will hear the alarm\n\nplace the origin at the center of your trigger box"
[
	target(target_destination) : "Target" : : "targetname of dlights to activate with the system"
	targetname(target_source) : "Name" : : "when fired, activates the alarm"
	health(integer) : "Health" : 10 : "defaults to 10"
	noise(sound) : "Siren sound" : : "the sound to play over the system (this would be the siren sound)"
	team(string) : "Team name" : : "Team name. Teamed alarm_boxes work in tandem (switches/lights syncronize)"
	// model(studio) : Model :  : "the model to use instead of the default models/mapobjects/electronics/alarmbox.md3" // <-- this doesn't work
	spawnflags(flags) = 
	[
		1 : "Start on" : 0 : "means the button is pushed in, any dlights are cycling, and alarms are sounding"
	]
]

