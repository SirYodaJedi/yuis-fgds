	dmg(integer) : "Radius damage" : : "How much radius damage should be done, defaults to 0"
	health(integer) : "Health" : 100 : "If health is set to '0' the brush will not be shootable."
	targetname(target_source) : "Name" : : "If set, no touch field will be spawned and a remote button or trigger field triggers the explosion."
	scriptname(string) : "Script when destroyed" : : "Script whose death is triggered when the object is destroyed"
	type(choices) : "Debris type" : "wood" : "Type of debris; default is wood." = 
	[
		"wood"  : "wood"  : "sound/world/boardbreak.wav"
		"glass"	: "glass" : "sound/world/glassbreak.wav"
		"metal"	: "metal" : "sound/world/metalbreak.wav"
		"gibs"  : "gibs"  : "sound/player/gibsplit1.wav"
		"brick"	: "brick" : "sound/world/brickfall.wav"
		"stone"	: "stone" : "sound/world/stonefall.wav"
	]
	mass(integer) : "Mass" : 75 : "Default 75.  This determines how much debris is emitted when it explodes.  You get one large chunk per 100 of mass (up to 8) and one small chunk per 25 of mass (up to 16).  So 800 gives the most."
	noise(sound) : "Sound when destroyed" : : "Sound to play when triggered. The explosive will default to a sound that matches its 'type'.  Use the sound name ''nosound'' (case insensitive) if you want it silent."
	
	spawnflags(flags) = 
	[
		1  : "Start invisible" : 0 : "Must be triggered before it will show in the world"
		2  : "Touchable" : 0 : "Means automatic use on player contact"
		4  : "Use shader for debris" : 0 : "will apply the shader used on the brush model to the debris"
		8  : "Low gravity" : 0 : "specifies that the debris will *always* fall slowly"
		32 : "Is tank" : 0 : "Will show as a tank on a command map if linked to by a trigger_objective_info"
	]
]

