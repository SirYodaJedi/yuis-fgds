@PointClass size(-13 -13 0, 13 13 40) color(200 0 200) flags(Angle) studio() base(ScriptName) = props_flamebarrel : "when selecting the OIL spawnflag you have the option of giving it a target\n\nthis will ensure that the oil sprite will show up where you want it\n\n( be sure to put it on the floor )\n\nthe default is in the middle of the barrel on the floor\n\n\n\nDefault model when no spawnflags is ''models/furniture/barrel/barrel_b.mdc''"
[
	// TODO - models exist in RtCW, but are missing in WolfET
	targetname(target_source) : "Name" : : "a misc_portal_surface portal surface indicator must point to this."
	target(target_destination) : "Spray oil at entity" : : "point this at an entity with the desired location of the oil"
	angle(angle) : "Yaw angle (Z)" : : "determines which way the lid will fly off when it explodes"
	model(choices) : "Editor model" : "models/furniture/barrel/barrel_b.md3" : "Which model to display in the map editor (no effect in-game)" =
	[
		"models/furniture/barrel/barrel_b.mdc.md3" : "Default (no spawnflags)"
		"models/furniture/barrel/barrel_d.mdc.md3" : "Smoking barrel (flag 1)"
		"models/furniture/barrel/barrel_c.mdc.md3" : "Oil drum (flag 4)"
	]
	spawnflags(flags) = 
	[
		1 : "Smoking barrel" : 0 : "Uses ''models/furniture/barrel/barrel_d.mdc''"
		2 : "No lid" : 0 : "Don't send lid flying when barrel explodes"
		4 : "Oil drum" : 0 : "Uses ''models/furniture/barrel/barrel_c.mdc''; takes priority over flag 1"
	]
]

@PointClass size(-8 -8 -8, 8 8 8) color(200 0 200) base(TargetName) = misc_portal_surface : "Portal surface indicator. This will lock on the brush face closest to it and identify as a portal. The view displayed on the portal surface is the view of the misc_portal_camera that this entity targets. Also used for mirrors (see Notes).\n\nThe entity must be no farther than 64 units away from the portal surface to lock onto it. To make a mirror, apply the common/mirror shader to the surface, place this entity near it but don't target a misc_portal_camera."
[
	target(target_destination) : "Camera to display" : : "point this to a misc_portal_camera that sees the view you want to display on the portal."
]

@PointClass size(-8 -8 -8, 8 8 8) color(200 0 200) flags(Angle) base(ScriptName) = misc_portal_camera : "Portal camera. This camera is used to project its view onto a portal surface in the level through the intermediary of a misc_portal_surface entity. Use the angles key or target a target_position or info_notnull entity to set the camera's pointing direction.\n\nBoth the setting angles key or targeting a target_position methods can be used to aim the camera. However, the target_position method is simpler. In both cases, the roll key must be used to set the roll angle. If either the SLOWROTATE or FASTROTATE spawnflag is set, then the roll value is irrelevant."
[
	targetname(target_source) : "Name" : : "a misc_portal_surface portal surface indicator must point to this."
	target(target_destination) : "Entity to point at" : : "point this to a target_position entity to set the camera's pointing direction."
	angles(angle) : "Pitch Yaw (Y Z)" : "0 0" : "this sets the pitch and yaw aiming angles of the portal camera (default 0 0). Use roll key to set roll angle."
	roll(angle) : "Roll angle (X)" : "180" : "roll angle of camera. A value of 0 is upside down and 180 is the same as the player's view."
	spawnflags(flags) = 
	[
		1 : "Rotate slowly" : 0 : "makes the portal camera rotate slowly along the roll axis."
		2 : "Rotate quickly" : 0 : "makes the portal camera rotate faster along the roll axis."
	]
]

@PointClass size(-8 -8 -8, 8 8 8) color(200 0 200) base(ScriptName) = target_teleporter : "Activating this will teleport players to the location of the targeted misc_teleporter_dest entity. Unlike trigger_teleport, this entity must be activated by a trigger and does NOT allow client prediction of events."
[
	targetname(target_source) : "Name" : : "activating trigger points to this."
	target(target_destination) : "Teleport destination" : : "this must point to a misc_teleporter_dest entity."
]

@SolidClass base(TargetName) = trigger_teleport : "Touching this will teleport players to the location of the targeted misc_teleporter_dest entity. This entity allows client prediction of events."
[
	target(target_destination) : "Teleport destination" : : "this must point to a misc_teleporter_dest entity."
]

@PointClass size(-32 -32 -24, 32 32 -16) color(200 0 200) flags(Angle) base(ScriptName) = misc_teleporter_dest : "Teleport destination location point for trigger_teleporter entities."
[
	targetname(target_source) : "Name" : : "make the trigger_teleporter point to this."
	angle(angle) : "Yaw angle (Z)" : : "direction in which player will look when teleported."
]

@PointClass size(-8 -8 -8, 8 8 8) color(200 0 200) base(ScriptName) = target_print : "This will print a message on the center of the screen when triggered. By default, all the clients will see the message."
[
	targetname(target_source) : "Name" : : "the activating trigger points to this."
	message(string) : "Message" : : "text string to print on screen."
	spawnflags(flags) = 
	[
		1 : "Axis only" : 0 : "only the axis players will see the message."
		2 : "Allies only" : 0 : "only allied team players will see the message."
		4 : "Activator only" : 0 : "only the player that activates the target will see the message."
	]
]
