@PointClass size(-8 -8 -8, 8 8 8) color(255 0 0) = target_speaker : "noise	wav file to play\n\nwait Seconds between auto triggerings, 0 = don't auto trigger\n\nrandom wait variance, default is 0\n\nvolume allows variance of the volume of the speaker, default is 255 (limit is 65535, but digital distortion will cut in long before then)\n\nGlobal and activator sounds can't be combined with looping.\n\nNormal sounds play each time the target is used.\n\nLooped sounds will be toggled by use functions.\n\nMultiple identical looping sounds will just increase volume without any speed cost.\n\nNot all functions may work, consider using in-game speaker placement tool for more flexibility and reliability."
[
	spawnflags(flags) = 
	[
		1 : "looped_on" : 0 : "Looping sound, starts on"
		2 : "looped_off" : 0 : "Looping sound, starts off"
		4 : "global" : 0 : "Plays at full volume throughout level"
		8 : "activator" : 0 : "Only play for player who activated"
		16 : "vis_multiple" : 0
		32 : "no_pvs" : 0 : "This sound plays regardless of whether the speaker is in the player's PVS"
	]
]
