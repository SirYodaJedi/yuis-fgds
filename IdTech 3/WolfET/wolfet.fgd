@SolidClass = func_door : "sound types:\n\n     0 - nosound (default)\n\n     1 - metal\n\n     2 - stone\n\n     3 - lab\n\n     4 - wood\n\n     5 - iron/jail\n\n     6 - portcullis\n\n     7 - wood (quiet)"
[
	key(integer) : Key : : "-1 for locked, key number for which key opens, 0 for open.  default '0' unless door is targeted.  (trigger_aidoor entities targeting this door do not affect the key status)"
	model2(studio) : Model : : "Optional .md3 model to also draw."
	angle(angle) : Angle : : "determines the opening direction. Use -1 for up, -2 for down."
	targetname(target_source) : Name : : "If set, no touch field will be spawned and a remote button or trigger field activates the door."
	speed(float) : Speed : : "movement speed (100 default)"
	closespeed(float) : Closespeed : : "Optional different movement speed for door when closing"
	wait(float) : Wait : : "Wait before returning (3 default, -1 = never return)"
	lip(float) : Lip : : "Lip remaining at end of move - how much door will be left sticking from adjacent solid geometry (8 default)"
	dmg(integer) : Dmg : : "Damage to inflict when blocked (2 default)"
	color(string) : Color : : "constantLight color"
	light(float) : Light : : "constantLight radius"
	health(integer) : Health : : "If set, the door must be shot open."
	team(string) : Team : : "Team name. Other doors with same team name will open/close in syncronicity."
	type(float) : Type : : "Use sounds based on construction of door."
	_targetname(string) : _targetname : : "Used to attach a misc_model entity to this entity."
	_lightmapscale(float) : _lightmapscale : : "Floating point value scaling the resolution of lightmaps on brushes/patches in this entity (default 1.0)."
	_castshadows;_cs(integer) : _castshadows;_cs : : "Allows per-entity control over shadow casting. Defaults to 0 on entities, 1 on world. 0 = no shadow casting. 1 = cast shadows on world. > 1 = cast shadows on entities with _rs (or _receiveshadows) with the corresponding value, AND world. Negative values imply same, but DO NOT cast shadows on world."
	_receiveshadows;_rs(integer) : _receiveshadows;_rs : : "Allows per-entity control over shadow reception. Defaults to 1 on everything (world shadows). 0 = receives NO shadows. > 1 = receive shadows only from corresponding keyed entities (see above) and world. < 1 = receive shadows ONLY from corresponding keyed entities."
	_celshader(string) : _celshader : : "Sets the cel shader used for this geometry. Note: omit the textures/ prefix."
	spawnflags(flags) = 
	[
		1 : "start_open" : 0 : "The door to moves to its destination when spawned, and operate in reverse.  It is used to temporarily or permanently close off an area when triggered (not useful for touch or takedamage doors)."
		2 : "toggle" : 0 : "Waits in both the start and end states for a trigger event."
		4 : "crusher" : 0 : "The door will not reverse direction when blocked and will keep damaging player until he dies or gets out of the way."
		8 : "touch" : 0
	]
]
@SolidClass = func_door_rotating : "You need to have an origin brush as part of this entity.\n\nThe center of that brush will be the point around which it is rotated. It will rotate around the Z axis by default.  You can check either the X_AXIS or Y_AXIS box to change that (only one axis allowed. If both X and Y are checked, the default of Z will be used).\n\nsound types:\n\n     0 - nosound (default)\n\n     1 - metal\n\n     2 - stone\n\n     3 - lab\n\n     4 - wood\n\n     5 - iron/jail\n\n     6 - portcullis\n\n     7 - wood (quiet)"
[
	key(integer) : Key : : "-1 for locked, key number for which key opens, 0 for open.  default '0' unless door is targeted.  (trigger_aidoor entities targeting this door do /not/ affect the key status)"
	model2(studio) : Model : : ".md3 model to also draw"
	degrees(float) : Degrees : : "How many degrees it will turn (90 default)"
	speed(float) : Speed : : "Movement speed (100 default)"
	closespeed(float) : Closespeed : : "Optional different movement speed for door closing"
	time(float) : Time : : "How many milliseconds it will take to open (1 second = 1000ms)"
	dmg(integer) : Dmg : : "Damage to inflict when blocked (2 default)"
	color(string) : Color : : "constantLight color"
	light(float) : Light : : "constantLight radius"
	team(string) : Team : : "Team name. Other doors with same team name will open/close in syncronicity."
	type(float) : Type : : "Use sounds based on construction of door."
	_targetname(string) : _targetname : : "Used to attach a misc_model entity to this entity."
	_lightmapscale(float) : _lightmapscale : : "Floating point value scaling the resolution of lightmaps on brushes/patches in this entity (default 1.0)."
	_castshadows;_cs(integer) : _castshadows;_cs : : "Allows per-entity control over shadow casting. Defaults to 0 on entities, 1 on world. 0 = no shadow casting. 1 = cast shadows on world. > 1 = cast shadows on entities with _rs (or _receiveshadows) with the corresponding value, AND world. Negative values imply same, but DO NOT cast shadows on world."
	_receiveshadows;_rs(integer) : _receiveshadows;_rs : : "Allows per-entity control over shadow reception. Defaults to 1 on everything (world shadows). 0 = receives NO shadows. > 1 = receive shadows only from corresponding keyed entities (see above) and world. < 1 = receive shadows ONLY from corresponding keyed entities."
	_celshader(string) : _celshader : : "Sets the cel shader used for this geometry. Note: omit the textures/ prefix."
	spawnflags(flags) = 
	[
		2 : "toggle" : 0 : "Waits in bith the open and closed states for a trigger event"
		4 : "x_axis" : 0 : "Door rotates around X axis instead of Z axis"
		8 : "y_axis" : 0 : "Door rotates around Y axis instead of Z axis"
		16 : "reverse" : 0 : "Door opens towards direction it is opened from"
		32 : "force" : 0 : "Door opens even when blocked"
		64 : "stayopen" : 0
	]
]
@SolidClass = func_explosive : "the default sounds are:\n\n  wood	- sound/world/boardbreak.wav\n\n  glass	- sound/world/glassbreak.wav\n\n  metal	- sound/world/metalbreak.wav\n\n  gibs	- sound/player/gibsplit1.wav\n\n  brick	- sound/world/brickfall.wav\n\n  stone	- sound/world/stonefall.wav\n\nIf you use model2, you must have an origin brush in the explosive with the center of the brush where you want the origin of the model to be.\n\nIf you want an explosion, set dmg and it will do a radius explosion of that amount at the center of the bursh."
[
	model2(studio) : Model : : "optional md3 to draw over the solid clip brush"
	wait(float) : Wait : : "How long (in seconds) to leave the model after it's 'dead'. '-1' leaves forever."
	dmg(integer) : Dmg : : "How much radius damage should be done, defaults to 0"
	health(integer) : Health : : "Default 100. If health is set to '0' the brush will not be shootable."
	targetname(target_source) : Name : : "If set, no touch field will be spawned and a remote button or trigger field triggers the explosion."
	scriptname(string) : Scriptname : : "Script whose death is triggered when the object is destroyed"
	type(string) : Type : : "Type of debris (glass, wood, metal, gibs, brick, rock, fabric) default is wood"
	mass(integer) : Mass : : "Default 75.  This determines how much debris is emitted when it explodes.  You get one large chunk per 100 of mass (up to 8) and one small chunk per 25 of mass (up to 16).  So 800 gives the most."
	noise(sound) : Noise : : "Sound to play when triggered.  The explosive will default to a sound that matches it's 'type'.  Use the sound name nosound (case in-sensitive) if you want it silent."
	_targetname(string) : _targetname : : "Used to attach a misc_model entity to this entity."
	_lightmapscale(float) : _lightmapscale : : "Floating point value scaling the resolution of lightmaps on brushes/patches in this entity (default 1.0)."
	_castshadows;_cs(integer) : _castshadows;_cs : : "Allows per-entity control over shadow casting. Defaults to 0 on entities, 1 on world. 0 = no shadow casting. 1 = cast shadows on world. > 1 = cast shadows on entities with _rs (or _receiveshadows) with the corresponding value, AND world. Negative values imply same, but DO NOT cast shadows on world."
	_receiveshadows;_rs(integer) : _receiveshadows;_rs : : "Allows per-entity control over shadow reception. Defaults to 1 on everything (world shadows). 0 = receives NO shadows. > 1 = receive shadows only from corresponding keyed entities (see above) and world. < 1 = receive shadows ONLY from corresponding keyed entities."
	_celshader(string) : _celshader : : "Sets the cel shader used for this geometry. Note: omit the textures/ prefix."
	spawnflags(flags) = 
	[
		1 : "start_invis" : 0 : "Must be triggered before it will show in the world"
		2 : "touchable" : 0 : "Means automatic use on player contact"
		4 : "useshader" : 0 : "will apply the shader used on the brush model to the debri"
		8 : "lowgrav" : 0 : "specifies that the debris will /always/ fall slowly"
		32 : "tank" : 0 : "Will show as a tank on a command map if linked to by a trigger_objective_info"
	]
]
